# Optional contact form overrides.
# Leave these unset to use the default FormSubmit integration built into src/pages/contact.astro.

PUBLIC_GA_MEASUREMENT_ID=G-C40VC19FCY

# Cloudflare cache purge (used by scripts/purge-cache.sh)
# CLOUDFLARE_ZONE_ID=your_zone_id
# CLOUDFLARE_API_TOKEN=your_api_token

# FormSubmit direct POST is the default and recommended static-site contact flow.
PUBLIC_CONTACT_FORM_PROVIDER=formsubmit
# PUBLIC_CONTACT_FORM_ENDPOINT=https://formsubmit.co/your@email.com
