---
interface Props {
	label: string;
	className?: string;
	iconWrapClass?: string;
	iconClass?: string;
}

const {
	label,
	className = "",
	iconWrapClass = "service-skew-card__cta-icon-wrap",
	iconClass = "service-skew-card__cta-icon",
} = Astro.props;
---

<span class={className}>
	<span>{label}</span>
	<span class={iconWrapClass} aria-hidden="true">
		<svg
			class={iconClass}
			viewBox="0 0 20 20"
			width="20"
			height="20"
			fill="none"
			stroke="currentColor"
			stroke-width="2.5"
			stroke-linecap="round"
			stroke-linejoin="round"
			focusable="false"
		>
			<path d="M5 15L15 5" />
			<path d="M8.8 5H15V11.2" />
		</svg>
	</span>
</span>
