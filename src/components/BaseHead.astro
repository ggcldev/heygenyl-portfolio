---
import "../styles/global.css";
import JsonLd from "./JsonLd.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "article" | "website";
  locale?: string;
  publishedTime?: string;
  modifiedTime?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
  ogImageAlt = title,
  ogType = "website",
  locale = "en_PH",
  publishedTime,
  modifiedTime,
  noIndex = false,
  schema = [],
} = Astro.props;

const siteName = "Hey Genyl";
const baseUrl = Astro.site ?? new URL("https://heygenyl.com");
const toTrailingSlashPath = (pathname: string) => {
  if (pathname === "/") return pathname;
  if (pathname.endsWith("/")) return pathname;
  if (/\.[a-z0-9]+$/i.test(pathname)) return pathname;
  return `${pathname}/`;
};
const canonicalPath = toTrailingSlashPath(Astro.url.pathname);
const canonicalURL = new URL(canonicalPath, baseUrl);
const imageURL = new URL(ogImage, baseUrl);
const cookieConsentStorageKey = "site_cookie_consent_v1";
const cookieConsentEventName = "cookie-consent-updated";
const gaMeasurementId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() || "G-C40VC19FCY";
const shouldLoadAnalytics = Boolean(gaMeasurementId) && import.meta.env.PROD;
const robots = noIndex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1E1E1E" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonicalURL.toString()} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteName} Blog`}
  href={new URL("/rss.xml", baseUrl).toString()}
/>
<script is:inline>
  (() => {
    try {
      const stored = localStorage.getItem("theme");
      const theme =
        stored === "light" || stored === "dark"
          ? stored
          : window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
      document.documentElement.dataset.theme = theme;
    } catch {
      // Ignore access errors (private mode/blocked storage).
    }
  })();
</script>
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="/fonts/space-grotesk/space-grotesk-latin-400-700.woff2"
  crossorigin
/>
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="/fonts/ibm-plex-mono/ibm-plex-mono-latin-400.woff2"
  crossorigin
/>
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="/fonts/inter/inter-latin-400-normal.woff2"
  crossorigin
/>
<link
  rel="preload"
  as="font"
  type="font/woff2"
  href="/fonts/inter/inter-latin-700-normal.woff2"
  crossorigin
/>
{
  shouldLoadAnalytics && (
    <script
      is:inline
      define:vars={{ gaMeasurementId, cookieConsentStorageKey, cookieConsentEventName }}
    >
      var __loadGa = function () {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;

        var s = document.createElement("script");
        s.src =
          "https://www.googletagmanager.com/gtag/js?id=" + gaMeasurementId;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", gaMeasurementId);
      };

      var __readCookieConsent = function () {
        try {
          return localStorage.getItem(cookieConsentStorageKey);
        } catch {
          return null;
        }
      };

      if (__readCookieConsent() === "accepted") {
        __loadGa();
      }

      window.addEventListener(cookieConsentEventName, function (event) {
        if (event instanceof CustomEvent && event.detail === "accepted") {
          __loadGa();
        }
      });
    </script>
  )
}

<meta property="og:site_name" content={siteName} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={locale} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL.toString()} />
<meta property="og:image" content={imageURL.toString()} />
<meta property="og:image:alt" content={ogImageAlt} />
{ogType === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL.toString()} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<JsonLd data={schema} />
