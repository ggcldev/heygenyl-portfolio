---
export interface Props {
	class?: string;
}
const { class: className = "" } = Astro.props as Props;
---

<button
	type="button"
	data-theme-toggle
	aria-label="Toggle theme"
	class={`theme-toggle ${className}`.trim()}
>
	<span class="sr-only">Toggle theme</span>
	<svg
		class="theme-toggle__icon theme-toggle__icon--sun inline-flex [html[data-theme='dark']_&]:hidden"
		viewBox="0 0 24 24"
		aria-hidden="true"
	>
		<path d="M12 3v1.5m0 15V21m8.25-9H21m-17.25 0H3m14.303 5.303 1.06 1.06M5.637 5.637 4.576 4.576m12.727 0-1.06 1.06M5.637 18.363l-1.06 1.06M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
	</svg>
	<svg
		class="theme-toggle__icon theme-toggle__icon--moon hidden [html[data-theme='dark']_&]:inline-flex"
		viewBox="0 0 24 24"
		aria-hidden="true"
	>
		<path d="M21.752 15.002A9.718 9.718 0 0112 21c-5.385 0-9.75-4.365-9.75-9.75 0-4.293 2.778-7.937 6.63-9.226.683-.228 1.423.277 1.367.996a7.501 7.501 0 008.002 8.002c.719-.056 1.224.684.996 1.367z" />
	</svg>
</button>
