---
import { siteConfig } from "../data/site";
---

<footer class="py-8">
  <div class="content-shell">
    <div class="grid gap-6 pt-8 pb-4 md:flex md:items-center md:justify-between" style="border-top: 1px solid var(--color-border);">
      <p class="text-sm text-muted m-0">
        {siteConfig.title} © {new Date().getFullYear()}.
      </p>
      <div class="md:text-right space-y-2 md:space-y-1">
        <p class="text-2xl sm:text-3xl font-semibold tracking-tight m-0">
          {siteConfig.location}
        </p>
        <p class="text-sm text-subtle m-0">
          Contact: <a class="underline" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>
      </div>
    </div>
  </div>
</footer>
