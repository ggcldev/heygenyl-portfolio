---
interface Props {
  data?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { data = [] } = Astro.props;
const items = Array.isArray(data) ? data : [data];
const serializeJsonLd = (item: Record<string, unknown>) =>
  JSON.stringify(item)
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");
---

{
  items
    .filter(Boolean)
    .map((item) => (
      <script
        is:inline
        type="application/ld+json"
        set:html={serializeJsonLd(item)}
      />
    ))
}
