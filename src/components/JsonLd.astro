---
interface Props {
  data?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { data = [] } = Astro.props;
const items = Array.isArray(data) ? data : [data];
---

{
  items
    .filter(Boolean)
    .map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))
}
