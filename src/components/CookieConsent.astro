---
const gaMeasurementId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() || "G-C40VC19FCY";
const shouldShowCookieBanner = Boolean(gaMeasurementId) && import.meta.env.PROD;
---

{
  shouldShowCookieBanner && (
    <>
      <section
        class="site-consent-banner"
        data-site-consent-banner
        role="dialog"
        aria-live="polite"
        aria-label="Cookie preferences"
      >
        <p class="site-consent-banner__copy">
          This site uses cookies for analytics (GA4) to understand site performance.
          You can accept or decline non-essential cookies. Read more in the{" "}
          <a href="/privacy-policy/">Privacy Policy</a>.
        </p>
        <div class="site-consent-banner__actions">
          <button class="button primary" type="button" data-site-consent-accept>
            Accept
          </button>
          <button class="button secondary" type="button" data-site-consent-reject>
            Decline
          </button>
        </div>
      </section>

      <script is:inline>
        (() => {
          const consentStorageKey = "site_cookie_consent_v1";
          const consentEventName = "cookie-consent-updated";
          const consentOpenEventName = "site-consent-open";
          const root = document.querySelector("[data-site-consent-banner]");
          if (!root) return;

          const acceptButton = root.querySelector("[data-site-consent-accept]");
          const rejectButton = root.querySelector("[data-site-consent-reject]");

          const readConsent = () => {
            try {
              return localStorage.getItem(consentStorageKey);
            } catch {
              return null;
            }
          };

          const writeConsent = (value) => {
            try {
              localStorage.setItem(consentStorageKey, value);
            } catch {
              // Ignore storage access failures and continue with runtime behavior.
            }

            window.dispatchEvent(new CustomEvent(consentEventName, { detail: value }));
          };

          const existing = readConsent();
          const hasStoredDecision =
            existing === "accepted" || existing === "rejected";
          root.hidden = hasStoredDecision;

          const openBanner = () => {
            root.hidden = false;
          };

          acceptButton?.addEventListener("click", () => {
            writeConsent("accepted");
            root.hidden = true;
          });

          rejectButton?.addEventListener("click", () => {
            writeConsent("rejected");
            root.hidden = true;
          });

          window.addEventListener(consentOpenEventName, openBanner);

          document.querySelectorAll("[data-site-consent-open]").forEach((node) => {
            node.addEventListener("click", (event) => {
              event.preventDefault();
              openBanner();
            });
          });
        })();
      </script>
    </>
  )
}
