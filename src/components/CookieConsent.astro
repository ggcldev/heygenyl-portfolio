---
const gaMeasurementId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() || "G-C40VC19FCY";
const shouldShowCookieBanner = Boolean(gaMeasurementId) && import.meta.env.PROD;
---

{
  shouldShowCookieBanner && (
    <>
      <section
        class="cookie-consent"
        data-cookie-consent
        role="dialog"
        aria-live="polite"
        aria-label="Cookie preferences"
        hidden
      >
        <p class="cookie-consent__copy">
          This site uses cookies for analytics (GA4) to understand site performance.
          You can accept or decline non-essential cookies. Read more in the{" "}
          <a href="/privacy-policy/">Privacy Policy</a>.
        </p>
        <div class="cookie-consent__actions">
          <button class="button primary" type="button" data-cookie-accept>
            Accept
          </button>
          <button class="button secondary" type="button" data-cookie-reject>
            Decline
          </button>
        </div>
      </section>

      <script is:inline>
        (() => {
          const consentStorageKey = "site_cookie_consent_v1";
          const consentEventName = "cookie-consent-updated";
          const root = document.querySelector("[data-cookie-consent]");
          if (!root) return;

          const acceptButton = root.querySelector("[data-cookie-accept]");
          const rejectButton = root.querySelector("[data-cookie-reject]");

          const readConsent = () => {
            try {
              return localStorage.getItem(consentStorageKey);
            } catch {
              return null;
            }
          };

          const writeConsent = (value) => {
            try {
              localStorage.setItem(consentStorageKey, value);
            } catch {
              // Ignore storage access failures and continue with runtime behavior.
            }

            window.dispatchEvent(new CustomEvent(consentEventName, { detail: value }));
          };

          const existing = readConsent();
          if (existing === "accepted" || existing === "rejected") {
            root.hidden = true;
            return;
          }

          root.hidden = false;

          acceptButton?.addEventListener("click", () => {
            writeConsent("accepted");
            root.hidden = true;
          });

          rejectButton?.addEventListener("click", () => {
            writeConsent("rejected");
            root.hidden = true;
          });
        })();
      </script>
    </>
  )
}
