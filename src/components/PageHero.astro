---
import { withBase } from "../utils/slugify";

interface Action {
  label: string;
  href: string;
  variant?: "primary" | "secondary";
  dataMl?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  compact?: boolean;
  chips?: string[];
  actions?: Action[];
  noteTitle?: string;
  noteCopy?: string;
}

const {
  eyebrow,
  title,
  intro,
  compact = false,
  chips = [],
  actions = [],
  noteTitle,
  noteCopy,
} = Astro.props;
---

<section class="content-shell">
  <div class="hero">
    <span class="eyebrow">{eyebrow}</span>
    <h1 style={compact ? "max-width: 16ch;" : undefined}>{title}</h1>
    <p>{intro}</p>

    {chips.length > 0 && <p class="post-meta">{chips.join(" / ")}</p>}

    {actions.length > 0 && (
      <div class="page-nav">
        {actions.map((action) => (
          <a
            href={withBase(action.href)}
            class:list={[
              "button",
              action.variant === "secondary" ? "secondary" : "primary",
            ]}
            {...(action.dataMl ? { "data-ml": action.dataMl } : {})}
          >
            {action.label}
          </a>
        ))}
      </div>
    )}

    {(noteTitle || noteCopy) && (
      <p class="post-meta">
        {noteTitle && <strong style="color: var(--color-ink)">{noteTitle}:</strong>}{" "}
        {noteCopy}
      </p>
    )}
  </div>
</section>
