---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { activeServicePages } from "../data/site";

const serviceNavLabelBySlug: Record<string, string> = {
  "seo-specialist": "SEO",
  "local-seo": "Local SEO",
  "wordpress-seo-expert": "WordPress",
};
---

<header class="site-header">
  <nav class="site-header__inner relative h-full w-full flex items-center justify-between">
    <a
      href="/"
      class="site-header__brand text-base-900 hover:text-base-500 font-bold uppercase"
    >
      Hey Genyl
    </a>

    <ThemeToggle class="hidden md:inline-flex absolute left-1/2 -translate-x-1/2" />

    <button
      id="nav-toggle"
      type="button"
      aria-label="Toggle navigation"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-haspopup="dialog"
      class="site-header__menu-toggle md:hidden text-base-900 hover:text-base-500 font-bold uppercase"
    >
      Menu
    </button>

    <div
      class="hidden md:flex items-center gap-3"
    >
      <div class="nav-dropdown">
        <HeaderLink class="nav-link text-[0.82rem] 2xl:text-base text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/services/">Services</HeaderLink>
        <div class="nav-dropdown-menu" aria-label="Services links">
          {activeServicePages.map((service) => (
            <HeaderLink
              class="nav-dropdown-link"
              activeClass="nav-dropdown-link-active"
              href={`/services/${service.slug}/`}
            >
              {serviceNavLabelBySlug[service.slug] ?? service.shortTitle}
            </HeaderLink>
          ))}
        </div>
      </div>
      <HeaderLink class="nav-link text-[0.82rem] 2xl:text-base text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/case-studies/">Case Studies</HeaderLink>
      <HeaderLink class="nav-link text-[0.82rem] 2xl:text-base text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/blog/">Blog</HeaderLink>
      <HeaderLink class="nav-link text-[0.82rem] 2xl:text-base text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/contact/">Contact</HeaderLink>
    </div>

    <div
      id="mobile-nav"
      role="dialog"
      aria-label="Mobile navigation"
      aria-modal="true"
      aria-hidden="true"
      tabindex="-1"
      hidden
      class="mobile-nav fixed inset-0 z-[1000] p-8 overflow-auto bg-[var(--color-paper)] text-[var(--color-ink)]"
    >
      <button
        id="mobile-close"
        type="button"
        aria-label="Close navigation"
        style="position:absolute;right:1rem;top:1rem;"
        class="mobile-nav__close font-bold uppercase"
      >
        Close
      </button>
      <div class="mobile-nav__list flex flex-col gap-2 items-start">
        <HeaderLink class="mobile-nav__link nav-link text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/services/">Services</HeaderLink>
        {activeServicePages.map((service) => (
          <a class="mobile-nav__sublink pl-4 text-muted hover:text-base-500 font-bold uppercase" href={`/services/${service.slug}/`}>
            {serviceNavLabelBySlug[service.slug] ?? service.shortTitle}
          </a>
        ))}
        <HeaderLink class="mobile-nav__link nav-link text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/case-studies/">Case Studies</HeaderLink>
        <HeaderLink class="mobile-nav__link nav-link text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/blog/">Blog</HeaderLink>
        <HeaderLink class="mobile-nav__link nav-link text-base-900 hover:text-base-500 font-bold uppercase" activeClass="text-ink nav-link-active" href="/contact/">Contact</HeaderLink>
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<script>
  import "../scripts/header";
</script>
