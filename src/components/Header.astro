---
import { toolPages } from "../data/site";

const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/services/", label: "Services" },
  { href: "/case-studies/", label: "Case Studies" },
  { href: "/blog/", label: "Blog" },
  { href: "/contact/", label: "Contact" },
];

const isActive = (href: string) =>
  href === "/"
    ? currentPath === "/"
    : currentPath === href || currentPath.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">HG</span>
      <span>
        <strong>Hey Genyl</strong>
        <small>SEO + WordPress</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} class:list={[isActive(item.href) && "is-active"]}>
          {item.label}
        </a>
      ))}

      <details class="nav-dropdown">
        <summary class:list={[currentPath.startsWith("/tools/") && "is-active"]}>
          Tools
        </summary>
        <div class="dropdown-panel">
          <a href="/tools/">All SEO tools</a>
          {toolPages.map((tool) => (
            <a href={`/tools/${tool.slug}/`}>{tool.shortTitle}</a>
          ))}
        </div>
      </details>
    </nav>

    <a class="button primary header-cta" href="/contact/">
      Hire an SEO specialist
    </a>
  </div>
</header>
