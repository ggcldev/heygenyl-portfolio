---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { activeServicePages, siteConfig } from "../../data/site";

const serviceRailLabelBySlug: Record<string, string> = {
  "seo-specialist": "SEO",
  "local-seo": "Local SEO",
  "wordpress-seo-expert": "WordPress",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "SEO and WordPress services",
    url: new URL("/services/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="SEO and WordPress Services | Hey Genyl"
  description="SEO and WordPress services hub covering freelance SEO specialist support, local SEO specialist work, and WordPress SEO expert implementation."
  schema={schema}
>
  <div class="services-page">
    <PageHero
      eyebrow="Services"
      title="SEO and WordPress Services Your Local Business and Agencies Actually Need."
      intro="Struggling to rank or dealing with a slow, broken WordPress site? I help local businesses and agencies fix both without the agency price tag."
      actions={[
        { label: "Let's Talk About Your Site", href: "/contact/", withArrow: true },
      ]}
    />

    <section class="content-shell services-scroll-hub" data-services-flow>
      <div class="services-scroll-hub__layout">
        <div class="services-scroll-hub__rail">
          <h2 class="text-sm 2xl:text-xl font-bold uppercase">All services</h2>
          <ul class="services-scroll-hub__status" aria-live="polite">
            {activeServicePages.map((service, index) => {
              const label = serviceRailLabelBySlug[service.slug] ?? service.shortTitle;
              const state = index === 0 ? "current" : "upcoming";

              return (
                <li
                  class="services-scroll-hub__status-item"
                  data-service-status-item
                  data-index={index}
                  data-state={state}
                  role="button"
                  tabindex="0"
                  aria-label={`Show ${label} service card`}
                >
                  <span class="services-scroll-hub__status-name">{label}</span>
                </li>
              );
            })}
          </ul>
        </div>

        <div class="services-scroll-hub__cards" data-services-cards>
          {activeServicePages.map((service, index) => (
            <a
              class="card services-scroll-hub__card block transition duration-300 ease-in-out hover:-translate-y-1"
              href={`/services/${service.slug}/`}
              data-service-card
              data-index={index}
            >
              <p class="eyebrow">{service.shortTitle}</p>
              <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
                {service.title}
              </h3>
              <p class="text-sm 2xl:text-lg text-muted mt-2">{service.summary}</p>
              <img
                src={`https://placehold.co/480x200/1a1a1a/555?text=${encodeURIComponent(service.shortTitle)}`}
                alt={`${service.shortTitle} illustration`}
                style="border-radius: var(--radius-card); opacity: 0.6;"
              />
              <span class="button primary" style="width: fit-content; margin-top: 1rem;">View Page</span>
            </a>
          ))}
        </div>
      </div>
    </section>
    <script>
      import "../../scripts/services-scroll-hub";
    </script>
  </div>
</BaseLayout>
