---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getToolBySlug } from "../../data/site";

const tool = getToolBySlug("meta-tag-analyzer");

const sampleMarkup = `<title>Freelance SEO Specialist | Hey Genyl</title>
<meta name="description" content="Freelance SEO specialist and WordPress designer/developer for service businesses and B2B brands." />
<link rel="canonical" href="https://www.heygenyl.com/" />
<meta property="og:title" content="Freelance SEO Specialist | Hey Genyl" />
<meta property="og:description" content="Freelance SEO specialist and WordPress designer/developer." />
<meta property="og:image" content="https://www.heygenyl.com/og-default.svg" />
<meta name="twitter:card" content="summary_large_image" />`;
---

<BaseLayout title={tool.metaTitle} description={tool.metaDescription}>
  <PageHero
    eyebrow="Tool"
    title={tool.title}
    intro={tool.summary}
    compact
    chips={tool.chips}
    actions={[
      { label: "Analyze sample", href: "#meta-input" },
      { label: "Back to tools", href: "/tools/", variant: "secondary" },
    ]}
    noteTitle="Why this version is static-safe"
    noteCopy={tool.note}
  />

  <section class="page-block section animate-rise">
    <div class="two-up">
      <div class="tool-form">
        <div class="field">
          <label for="meta-input">Paste HTML head markup</label>
          <textarea id="meta-input" data-meta-input>{sampleMarkup}</textarea>
        </div>

        <button class="button primary" type="button" data-run-meta-analysis>
          Run analysis
        </button>
      </div>

      <article class="tool-panel">
        <p class="card-label">Analysis</p>
        <h3>Coverage and length review</h3>
        <p class="card-copy">The checker looks for title, description, canonical, robots, Open Graph, and Twitter essentials.</p>
        <div class="result-table" data-meta-results></div>
      </article>
    </div>
  </section>

  <script>
    const input = document.querySelector("[data-meta-input]");
    const trigger = document.querySelector("[data-run-meta-analysis]");
    const output = document.querySelector("[data-meta-results]");

    const getMeta = (doc, selector) => {
      const node = doc.querySelector(selector);
      return node?.getAttribute("content") || "";
    };

    const evaluate = () => {
      if (!(input instanceof HTMLTextAreaElement) || !(output instanceof HTMLElement)) return;
      const parser = new DOMParser();
      const doc = parser.parseFromString(input.value, "text/html");

      const title = doc.querySelector("title")?.textContent?.trim() || "";
      const description = getMeta(doc, 'meta[name="description"]');
      const canonical = doc.querySelector('link[rel="canonical"]')?.getAttribute("href") || "";
      const robots = getMeta(doc, 'meta[name="robots"]');
      const ogTitle = getMeta(doc, 'meta[property="og:title"]');
      const ogDescription = getMeta(doc, 'meta[property="og:description"]');
      const ogImage = getMeta(doc, 'meta[property="og:image"]');
      const twitterCard = getMeta(doc, 'meta[name="twitter:card"]');

      const checks = [
        {
          label: "Title",
          value: title || "Missing",
          status: title ? (title.length >= 45 && title.length <= 60 ? "good" : "warn") : "bad",
          note: title ? `${title.length} characters` : "Add a unique page title",
        },
        {
          label: "Meta description",
          value: description || "Missing",
          status:
            description
              ? description.length >= 120 && description.length <= 160
                ? "good"
                : "warn"
              : "bad",
          note: description ? `${description.length} characters` : "Add a summary for the page",
        },
        {
          label: "Canonical",
          value: canonical || "Missing",
          status: canonical ? "good" : "bad",
          note: canonical ? "Canonical present" : "Set a canonical URL",
        },
        {
          label: "Robots",
          value: robots || "Missing",
          status: robots ? "good" : "warn",
          note: robots || "Optional, but useful for explicit directives",
        },
        {
          label: "OG title",
          value: ogTitle || "Missing",
          status: ogTitle ? "good" : "warn",
          note: ogTitle ? "Present" : "Add Open Graph title",
        },
        {
          label: "OG description",
          value: ogDescription || "Missing",
          status: ogDescription ? "good" : "warn",
          note: ogDescription ? "Present" : "Add Open Graph description",
        },
        {
          label: "OG image",
          value: ogImage || "Missing",
          status: ogImage ? "good" : "warn",
          note: ogImage ? "Present" : "Add a share image",
        },
        {
          label: "Twitter card",
          value: twitterCard || "Missing",
          status: twitterCard ? "good" : "warn",
          note: twitterCard ? "Present" : "Add twitter:card",
        },
      ];

      output.innerHTML = `
        <table>
          <thead>
            <tr>
              <th>Check</th>
              <th>Value</th>
              <th>Status</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            ${checks
              .map(
                (check) => `
                  <tr>
                    <td>${check.label}</td>
                    <td>${check.value}</td>
                    <td><span class="status-pill ${check.status}">${check.status}</span></td>
                    <td>${check.note}</td>
                  </tr>
                `,
              )
              .join("")}
          </tbody>
        </table>
      `;
    };

    if (trigger instanceof HTMLButtonElement) {
      trigger.addEventListener("click", evaluate);
    }

    evaluate();
  </script>
</BaseLayout>
