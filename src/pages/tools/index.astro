---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig, toolPages } from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free SEO tools",
    url: new URL("/tools/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="Free SEO Tools | Hey Genyl"
  description="Free SEO tools hub for a schema generator, meta tag analyzer, and starter 404 checker."
  schema={schema}
>
  <PageHero
    eyebrow="Tools hub"
    title="Free SEO tools that fit a static Astro stack."
    intro="These tools are intentionally browser-first. Two of them run entirely client-side, while the 404 checker is designed as a starter interface that can grow into a serverless crawler later."
    chips={["Free SEO tools", "Client-side utilities", "Serverless-ready 404 checker"]}
    actions={[
      { label: "Open schema generator", href: "/tools/schema-generator/" },
      { label: "Contact for custom tools", href: "/contact/", variant: "secondary" },
    ]}
    noteTitle="Hosting note"
    noteCopy="Schema and metadata tools work perfectly on shared hosting because they do not require server-side requests."
  />

  <section class="page-block section animate-rise">
    <div class="cards">
      {toolPages.map((tool) => (
        <a class="card card-link" href={`/tools/${tool.slug}/`}>
          <p class="card-label">{tool.shortTitle}</p>
          <h3 class="card-title">{tool.title}</h3>
          <p class="card-copy">{tool.summary}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
