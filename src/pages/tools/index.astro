---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free SEO tools",
    url: new URL("/tools/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="Free SEO Tools | Hey Genyl"
  description="SEO tools page for upcoming utilities and future releases."
  schema={schema}
>
  <PageHero
    eyebrow="Tools hub"
    title="SEO tools are coming soon."
    intro="I’m currently prioritizing service pages and case studies first. This section will be used for practical SEO utilities after the core site structure is finalized."
    chips={["Tools in progress", "Service-first rollout", "SEO utility roadmap"]}
    actions={[
      { label: "See services", href: "/services/" },
      { label: "Contact", href: "/contact/", variant: "secondary" },
    ]}
    noteTitle="Status"
    noteCopy="Tool pages are temporarily removed while the service pages are being built and deployed."
  />

  <section class="content-shell">
    <div class="grid grid-cols-1 gap-y-24 md:grid-cols-3 py-24">
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Current focus</h2>
        <p class="text-sm text-muted mt-2">
          Services first, then tools. This keeps the launch scope cleaner and
          helps you publish faster without half-finished utility pages.
        </p>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 gap-y-8">
        <article class="card">
          <p class="eyebrow">Planned utilities</p>
          <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
            Schema Generator, Meta Tag Analyzer, and 404 Checker
          </h3>
          <p class="text-sm 2xl:text-lg text-muted mt-2">
            These tools are queued for the next build cycle. For now, this page
            stays live as a placeholder to preserve the /tools route in your
            site architecture.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
