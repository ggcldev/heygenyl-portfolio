---
import { Picture } from "astro:assets";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { caseStudies, siteConfig } from "../../data/site";
import desertItSolutionsImage from "../../assets/case-studies/desert-it-solutions/desert-it-solutions-img-1-desktop.webp";
import worksAutoCenterImage from "../../assets/case-studies/the-works-auto-center/the-works-auto-center-img-1-desktop.webp";
import everythingProbateImage from "../../assets/case-studies/everything-probate/everything-probate-img-1-deskto.webp";

const caseStudyCardMedia = {
  "desert-it-solutions-msp": {
    src: desertItSolutionsImage,
    alt: "Desert IT Solutions case study preview",
  },
  "the-works-auto-center-car-detailing": {
    src: worksAutoCenterImage,
    alt: "The Works Auto Center case study preview",
  },
  "everything-probate-legal-firm": {
    src: everythingProbateImage,
    alt: "Everything Probate case study preview",
  },
} as const;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "SEO case studies",
    url: new URL("/case-studies/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="SEO Case Studies | Hey Genyl"
  description="Case studies hub for local service SEO, law firm SEO, WordPress redesigns, and B2B enterprise search work."
  schema={schema}
>
  <div class="case-studies-page">
    <PageHero
      eyebrow="Case Studies"
      title="Here's What I've Been Working On"
      intro="Every project starts with a different problem. Here is how I diagnosed each one, what I did about it, and what actually moved the needle."
      actions={[
        { label: "Let's Jump on a Call", href: "/contact/", withArrow: true },
      ]}
    />

    <section class="content-shell">
      <div class="grid grid-cols-1 gap-y-8 py-24">
        <div class="mx-auto w-full max-w-3xl grid grid-cols-1 gap-y-8">
          {caseStudies.map((study) => {
            const media =
              caseStudyCardMedia[study.slug as keyof typeof caseStudyCardMedia];

            return (
              <a
                class="block w-full text-left transition duration-200 ease-out hover:opacity-90"
                href={`/case-studies/${study.slug}/`}
              >
                <article class="grid gap-4 sm:grid-cols-[240px_minmax(0,1fr)] sm:items-start">
                  <div class="overflow-hidden">
                    <Picture
                      src={media.src}
                      alt={media.alt}
                      formats={["avif", "webp"]}
                      fallbackFormat="webp"
                      widths={[360, 480, 640, 800]}
                      sizes="(max-width: 639px) 100vw, 240px"
                      class="h-full w-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>

                  <div class="grid gap-2">
                    <p class="eyebrow">{study.shortTitle}</p>
                    <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
                      {study.title}
                    </h3>
                    <p class="case-study-card__summary text-sm 2xl:text-lg text-muted m-0">
                      {study.summary}
                    </p>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
