---
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { caseStudies, siteConfig } from "../../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "SEO case studies",
    url: new URL("/case-studies/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="SEO Case Studies | Hey Genyl"
  description="Case studies hub for local service SEO, law firm SEO, WordPress redesigns, and B2B enterprise search work."
  schema={schema}
>
  <PageHero
    eyebrow="Case studies hub"
    title="SEO case studies that can be specific without pretending every project looks the same."
    intro="These pages are structured to show problem framing, implementation thinking, and business outcomes by niche. Replace the starter proof blocks with your real screenshots and metrics."
    chips={["SEO case studies", "Niche-specific pages", "Portfolio-ready structure"]}
    actions={[
      { label: "Discuss your site", href: "/contact/" },
      { label: "Open service hub", href: "/services/", variant: "secondary" },
    ]}
    noteTitle="Publishing note"
    noteCopy="Keep the page names niche-specific. It helps both relevance and memorability."
  />

  <section class="content-shell">
    <div class="grid grid-cols-1 gap-y-24 md:grid-cols-3 py-24">
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">All case studies</h2>
        <p class="text-sm text-muted mt-2">
          Each route is meant to feel like a specific engagement, not a generic
          portfolio entry.
        </p>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
        {caseStudies.map((study) => (
          <a
            class="card block transition duration-300 ease-in-out hover:-translate-y-1"
            href={`/case-studies/${study.slug}/`}
          >
            <p class="eyebrow">{study.shortTitle}</p>
            <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
              {study.title}
            </h3>
            <p class="text-sm 2xl:text-lg text-muted mt-2">{study.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
