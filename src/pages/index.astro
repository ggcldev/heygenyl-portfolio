---
import { getCollection } from "astro:content";
import Hero from "../components/Hero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  caseStudies,
  processSteps,
  servicePages,
  siteConfig,
} from "../data/site";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: siteConfig.name,
    description: siteConfig.description,
    url: siteConfig.url,
    areaServed: "Worldwide",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bacolod City",
      addressCountry: "PH",
    },
  },
];
---

<BaseLayout
  title="Freelance SEO Specialist | Hey Genyl"
  description="Freelance SEO specialist and WordPress designer/developer building fast, search-first portfolio, service, and blog experiences."
  schema={homeSchema}
>
  <Hero
    title="Hey Genyl"
    role="Freelance SEO specialist"
    description="SEO specialist and WordPress designer/developer building lean, search-first websites for local service brands and B2B teams."
    location={siteConfig.location}
    actions={[
      { label: "View services", href: "/services/" },
      { label: "Contact", href: "/contact/" },
    ]}
  />

  <section class="content-shell">
    <div
      class="grid grid-cols-1 gap-y-24 md:grid-cols-3 border-b py-24"
      style="border-color: var(--color-border);"
    >
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Featured Projects</h2>
        <p class="text-sm text-muted mt-2">
          Selected work that shows SEO thinking, execution, and cleaner
          structure across different types of projects.
        </p>
      </div>

      <div class="md:col-span-2 flat-panel-grid grid-cols-1 md:grid-cols-2">
        {caseStudies.map((study) => (
          <a
            class="flat-panel"
            href={`/case-studies/${study.slug}/`}
          >
            <p class="flat-panel__kicker">{study.shortTitle}</p>
            <h3 class="flat-panel__title">{study.title}</h3>
            <p class="flat-panel__copy">{study.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="content-shell">
    <div
      class="grid grid-cols-1 gap-y-24 md:grid-cols-3 border-b py-24"
      style="border-color: var(--color-border);"
    >
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Process</h2>
        <p class="text-sm text-muted mt-2">
          The portfolio is also your publishing system, so the workflow has to
          stay clean.
        </p>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 gap-y-8">
        {processSteps.map((step, index) => (
          <article class="card">
            <p class="eyebrow">Step {index + 1}</p>
            <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
              {step.title}
            </h3>
            <p class="text-sm 2xl:text-lg text-muted mt-2">{step.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="content-shell">
    <div
      class="grid grid-cols-1 gap-y-24 md:grid-cols-3 border-b py-24"
      style="border-color: var(--color-border);"
    >
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Services</h2>
        <p class="text-sm text-muted mt-2">
          Split the offer by how clients actually search so each service page
          can carry tighter intent.
        </p>
      </div>

      <div class="md:col-span-2 flat-panel-grid grid-cols-1 md:grid-cols-2">
        {servicePages.map((service) => (
          <a
            class="flat-panel"
            href={`/services/${service.slug}/`}
          >
            <p class="flat-panel__kicker">{service.shortTitle}</p>
            <h3 class="flat-panel__title">{service.title}</h3>
            <p class="flat-panel__copy">{service.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="content-shell">
    <div
      class="grid grid-cols-1 gap-y-24 md:grid-cols-3 border-b py-24"
      style="border-color: var(--color-border);"
    >
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Blog</h2>
        <p class="text-sm text-muted mt-2">
          Weekly publishing reinforces the service pages, case studies, and tool
          pages instead of competing with them.
        </p>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
        {posts.map((post) => (
          <a
            class="card block transition duration-300 ease-in-out hover:-translate-y-1"
            href={`/blog/${post.id}/`}
          >
            <p class="eyebrow">
              {post.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </p>
            <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
              {post.data.title}
            </h3>
            <p class="text-sm 2xl:text-lg text-muted mt-2">
              {post.data.excerpt}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="content-shell">
    <div class="grid grid-cols-1 gap-y-24 md:grid-cols-3 py-24">
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Next Move</h2>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
        <article class="card">
          <p class="eyebrow">Before launch</p>
          <p class="text-sm 2xl:text-lg text-muted">
            Replace the starter proof points with real metrics, screenshots, and
            your final project intake details.
          </p>
        </article>

        <article class="card">
          <p class="eyebrow">After launch</p>
          <p class="text-sm 2xl:text-lg text-muted">
            Keep publishing. The site is strongest when services, proof, blog
            posts, and tools keep feeding each other.
          </p>
          <div class="page-nav mt-4">
            <a class="button primary" href="/contact/">Open contact page</a>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
