---
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Contact Hey Genyl",
    url: new URL("/contact/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="Hire an SEO Specialist | Hey Genyl"
  description="Contact page for SEO consulting, WordPress design, development support, audits, and project inquiries."
  schema={schema}
>
  <PageHero
    eyebrow="Contact"
    title="Hire an SEO specialist without turning the first call into a discovery marathon."
    intro="Use this page to funnel inquiries from Upwork, direct outreach, referrals, and portfolio traffic. The form currently opens an email draft so it works on static hosting."
    chips={["Static-site friendly", "Email-first intake", "Easy to replace later"]}
    actions={[
      { label: "Email directly", href: `mailto:${siteConfig.email}` },
      { label: "View services", href: "/services/", variant: "secondary" },
    ]}
    noteTitle="Replace before launch"
    noteCopy={`Update ${siteConfig.email} if your final domain email changes.`}
  />

  <section class="content-shell">
    <div class="grid grid-cols-1 gap-y-24 md:grid-cols-3 py-24">
      <div class="md:sticky md:top-24 self-start">
        <h2 class="text-sm 2xl:text-xl font-bold uppercase">Project intake</h2>
        <p class="text-sm text-muted mt-2">
          Keep the first message specific enough that the right clients can
          self-qualify.
        </p>
      </div>

      <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
        <article class="card">
          <p class="eyebrow">What to include</p>
          <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
            Make it easy for the right clients to self-qualify.
          </h3>
          <ul class="m-0 mt-4 pl-5 text-sm 2xl:text-lg text-muted grid gap-2">
            <li>What kind of site or business you are working on</li>
            <li>Which service page made them reach out</li>
            <li>Whether they need strategy, implementation, or both</li>
            <li>Any timing or launch deadline that affects priorities</li>
          </ul>
        </article>

        <form
          class="form-surface grid gap-5"
          data-contact-form
          data-contact-email={siteConfig.email}
        >
          <div class="field-group">
            <label for="name">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              class="field-control"
              placeholder="Your name"
              required
            />
          </div>

          <div class="field-group">
            <label for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              class="field-control"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="field-group">
            <label for="service">Service needed</label>
            <select id="service" name="service" class="field-control">
              <option>Freelance SEO specialist</option>
              <option>Local SEO consultant</option>
              <option>Technical SEO specialist</option>
              <option>SEO audit service</option>
              <option>WordPress website designer</option>
              <option>WordPress developer for hire</option>
            </select>
          </div>

          <div class="field-group">
            <label for="message">Project details</label>
            <textarea
              id="message"
              name="message"
              class="field-control"
              placeholder="Tell me about the site, what is not working, and what kind of support you need."
              required
            />
          </div>

          <p class="muted-note">
            On submit, this form opens your default mail client with the details
            pre-filled. Replace it later with FormSubmit, Basin, or your
            preferred endpoint if you want browser-based submissions.
          </p>

          <div class="page-nav">
            <button class="button primary" type="submit">Draft email inquiry</button>
            <a class="button secondary" href={`mailto:${siteConfig.email}`}>
              Email directly
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-contact-form]");

    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const contactEmail = form.dataset.contactEmail || "hello@heygenyl.com";
        const name = String(data.get("name") || "");
        const email = String(data.get("email") || "");
        const service = String(data.get("service") || "");
        const message = String(data.get("message") || "");

        const subject = `New inquiry: ${service}`;
        const body = [
          `Name: ${name}`,
          `Email: ${email}`,
          `Service: ${service}`,
          "",
          message,
        ].join("\n");

        window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      });
    }
  </script>
</BaseLayout>
