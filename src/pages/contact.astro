---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";

const contactPath = "/contact/";
const contactThanksPath = "/contact/thanks/";
const contactPageUrl = new URL(contactPath, siteConfig.url).toString();
const contactThanksUrl = new URL(contactThanksPath, siteConfig.url).toString();
const contactFormProvider =
  import.meta.env.PUBLIC_CONTACT_FORM_PROVIDER?.trim().toLowerCase() ||
  "formsubmit";
const configuredContactFormEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() || "";
const configuredContactFormAjaxEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_AJAX_ENDPOINT?.trim() || "";
const usesFormSubmit = contactFormProvider === "formsubmit";
const contactFormEndpoint = usesFormSubmit
  ? configuredContactFormEndpoint || `https://formsubmit.co/${siteConfig.email}`
  : configuredContactFormEndpoint;
const contactFormAjaxEndpoint = usesFormSubmit
  ? configuredContactFormAjaxEndpoint || `https://formsubmit.co/ajax/${siteConfig.email}`
  : configuredContactFormAjaxEndpoint || configuredContactFormEndpoint;
const usesAjaxContactFlow = contactFormAjaxEndpoint.length > 0;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim() || "";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Contact Hey Genyl",
    url: new URL("/contact/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="Hire an SEO Specialist | Hey Genyl"
  description="Contact page for SEO consulting, WordPress design, development support, audits, and project inquiries."
  schema={schema}
>
  <div class="contact-page">
    <section class="content-shell py-24">
      <div class="grid grid-cols-1 items-start gap-10 md:grid-cols-2 md:gap-12">
        <div class="hero pt-8 md:pt-10">
          <p class="eyebrow m-0">Contact</p>
          <h1>Your Competitors Are Ranking. Let's Fix That.</h1>
          <h2 class="m-0 text-[clamp(1.05rem,1.6vw,1.3rem)] font-bold uppercase">
            What Happens After You Reach Out
          </h2>
          <p>
            I work with local businesses and agencies that are tired of being invisible on Google. If you need someone to dig into your site, figure out what's holding you back, and actually fix it, that's exactly what I do. I'm currently taking on freelance projects and open to full-time roles where SEO is taken seriously, not treated as an afterthought.
          </p>
        </div>

        <form
          class="form-surface contact-form grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-x-8 md:gap-y-7"
          action={contactFormEndpoint}
          method="POST"
          data-contact-form
          data-contact-ajax-endpoint={usesAjaxContactFlow ? contactFormAjaxEndpoint : undefined}
          data-contact-success-url={contactThanksPath}
          data-contact-min-seconds={usesAjaxContactFlow ? "4" : undefined}
        >
          {usesFormSubmit && (
            <>
              <input
                type="hidden"
                name="_subject"
                value="New portfolio inquiry from heygenyl.com"
              />
              <input type="hidden" name="_next" value={contactThanksUrl} />
              <input type="hidden" name="_url" value={contactPageUrl} />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_captcha" value="true" />
              <div class="field-honeypot" aria-hidden="true">
                <label for="_honey">Leave this field empty</label>
                <input
                  id="_honey"
                  name="_honey"
                  type="text"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>
            </>
          )}

          <div class="field-group">
            <label for="name">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              class="field-control"
              placeholder="Your name"
              required
            />
          </div>

          <div class="field-group">
            <label for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              class="field-control"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="field-group md:col-span-2">
            <label for="websiteUrl">Your Website URL</label>
            <input
              id="websiteUrl"
              name="websiteUrl"
              type="url"
              class="field-control"
              placeholder="https://yourwebsite.com"
            />
          </div>

          <div class="field-group md:col-span-2">
            <label for="service">Service needed</label>
            <select id="service" name="service" class="field-control">
              <option>SEO</option>
              <option>Local SEO</option>
              <option>Website Audit</option>
              <option>Technical Audit</option>
              <option>WordPress Design</option>
              <option>WordPress SEO</option>
              <option>Others (Specificy in Project Details)</option>
            </select>
          </div>

          <div class="field-group md:col-span-2">
            <label for="message">Project details</label>
            <textarea
              id="message"
              name="message"
              class="field-control"
              placeholder="Tell me about the site, what is not working, and what kind of support you need."
              required
            />
          </div>

          {turnstileSiteKey && (
            <div class="field-group md:col-span-2">
              <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark" data-appearance="always"></div>
            </div>
          )}

          <p class="muted-note md:col-span-2">
            {usesAjaxContactFlow
              ? "Submissions are sent from the browser and redirect to an on-site thank-you page. If the form fails, use the direct email link below."
              : "FormSubmit may ask for a verification challenge before sending. After successful submission, you will be redirected to the thank-you page."}
          </p>

          <p class="form-feedback md:col-span-2" data-contact-feedback aria-live="polite" hidden></p>

          <div class="page-nav md:col-span-2">
            <button class="button primary button-with-arrow" type="submit">
              <span data-submit-label>Send Message</span>
              <span class="button-arrow-circle" aria-hidden="true">
                <svg
                  class="button-arrow-icon"
                  viewBox="0 0 20 20"
                  width="20"
                  height="20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  focusable="false"
                >
                  <path d="M5 15L15 5" />
                  <path d="M8.8 5H15V11.2" />
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </section>
  </div>

  {turnstileSiteKey && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}
  <script>
    import "../scripts/contact-form";
  </script>
</BaseLayout>
