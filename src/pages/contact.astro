---
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../data/site";

const contactPath = "/contact/";
const contactThanksPath = "/contact/thanks/";
const contactPageUrl = new URL(contactPath, siteConfig.url).toString();
const contactThanksUrl = new URL(contactThanksPath, siteConfig.url).toString();
const contactFormProvider =
  import.meta.env.PUBLIC_CONTACT_FORM_PROVIDER?.trim().toLowerCase() ||
  "formsubmit";
const configuredContactFormEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() || "";
const configuredContactFormAjaxEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_AJAX_ENDPOINT?.trim() || "";
const usesFormSubmit = contactFormProvider === "formsubmit";
const contactFormEndpoint = usesFormSubmit
  ? configuredContactFormEndpoint || `https://formsubmit.co/${siteConfig.email}`
  : configuredContactFormEndpoint;
const contactFormAjaxEndpoint = usesFormSubmit
  ? configuredContactFormAjaxEndpoint || `https://formsubmit.co/ajax/${siteConfig.email}`
  : configuredContactFormAjaxEndpoint || configuredContactFormEndpoint;
const usesAjaxContactFlow = contactFormAjaxEndpoint.length > 0;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY?.trim() || "";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Contact Hey Genyl",
    url: new URL("/contact/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="Hire an SEO Specialist | Hey Genyl"
  description="Contact page for SEO consulting, WordPress design, development support, audits, and project inquiries."
  schema={schema}
>
  <div class="contact-page">
    <PageHero
      eyebrow="Contact"
      title="Hire an SEO specialist without turning the first call into a discovery marathon."
      intro="Use this page to funnel inquiries from Upwork, direct outreach, referrals, and portfolio traffic. The form now submits in the browser and still works on static hosting."
      chips={["Static-hosting ready", "Browser-based intake", "Direct-email fallback"]}
      actions={[
        { label: "Email directly", href: "#", dataMl: "hi|heygenyl.com" },
        { label: "View services", href: "/services/", variant: "secondary" },
      ]}
      noteTitle="Submission flow"
      noteCopy={
        usesFormSubmit && !usesAjaxContactFlow
          ? `This route uses FormSubmit with native verification by default. Update ${siteConfig.email} if your final inbox changes, and approve the first live submission email from FormSubmit before launch.`
          : usesFormSubmit && usesAjaxContactFlow
          ? `This route uses FormSubmit AJAX mode with client-side anti-spam checks. Keep your endpoint private and monitor for abuse.`
          : "This route is wired to your configured form endpoint. Verify the endpoint and thank-you redirect before launch."
      }
    />

    <section class="content-shell">
      <div class="grid grid-cols-1 gap-y-24 md:grid-cols-3 py-24">
        <div class="md:sticky md:top-24 self-start">
          <h2 class="text-sm 2xl:text-xl font-bold uppercase">Project intake</h2>
          <p class="text-sm text-muted mt-2">
            Keep the first message specific enough that the right clients can
            self-qualify.
          </p>
        </div>

        <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-8">
          <article class="card">
            <p class="eyebrow">What to include</p>
            <h3 class="text-sm 2xl:text-xl font-bold uppercase m-0">
              Make it easy for the right clients to self-qualify.
            </h3>
            <ul class="m-0 mt-4 pl-5 text-sm 2xl:text-lg text-muted grid gap-2">
              <li>What kind of site or business you are working on</li>
              <li>Which service page made them reach out</li>
              <li>Whether they need strategy, implementation, or both</li>
              <li>Any timing or launch deadline that affects priorities</li>
            </ul>
          </article>

          <form
            class="form-surface grid gap-5"
            action={contactFormEndpoint}
            method="POST"
            data-contact-form
            data-contact-ajax-endpoint={usesAjaxContactFlow ? contactFormAjaxEndpoint : undefined}
            data-contact-success-url={contactThanksPath}
            data-contact-min-seconds={usesAjaxContactFlow ? "4" : undefined}
          >
            {usesFormSubmit && (
              <>
                <input
                  type="hidden"
                  name="_subject"
                  value="New portfolio inquiry from heygenyl.com"
                />
                <input type="hidden" name="_next" value={contactThanksUrl} />
                <input type="hidden" name="_url" value={contactPageUrl} />
                <input type="hidden" name="_template" value="table" />
                <input type="hidden" name="_captcha" value="true" />
                <div class="field-honeypot" aria-hidden="true">
                  <label for="_honey">Leave this field empty</label>
                  <input
                    id="_honey"
                    name="_honey"
                    type="text"
                    tabindex="-1"
                    autocomplete="off"
                  />
                </div>
              </>
            )}

            <div class="field-group">
              <label for="name">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                class="field-control"
                placeholder="Your name"
                required
              />
            </div>

            <div class="field-group">
              <label for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                class="field-control"
                placeholder="you@example.com"
                required
              />
            </div>

            <div class="field-group">
              <label for="service">Service needed</label>
              <select id="service" name="service" class="field-control">
                <option>Freelance SEO specialist</option>
                <option>Local SEO consultant</option>
                <option>Technical SEO specialist</option>
                <option>SEO audit service</option>
                <option>WordPress website designer</option>
                <option>WordPress developer for hire</option>
              </select>
            </div>

            <div class="field-group">
              <label for="message">Project details</label>
              <textarea
                id="message"
                name="message"
                class="field-control"
                placeholder="Tell me about the site, what is not working, and what kind of support you need."
                required
              />
            </div>

            {turnstileSiteKey && (
              <div class="field-group">
                <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark" data-appearance="always"></div>
              </div>
            )}

            <p class="muted-note">
              {usesAjaxContactFlow
                ? "Submissions are sent from the browser and redirect to an on-site thank-you page. If the form fails, use the direct email link below."
                : "FormSubmit may ask for a verification challenge before sending. After successful submission, you will be redirected to the thank-you page."}
            </p>

            <p class="form-feedback" data-contact-feedback aria-live="polite" hidden></p>

            <div class="page-nav">
              <button class="button primary" type="submit">Send project inquiry</button>
              <a class="button secondary" href="#" data-ml="hi|heygenyl.com">
                Email directly
              </a>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>

  {turnstileSiteKey && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}
  <script>
    import "../scripts/contact-form";
  </script>
</BaseLayout>
