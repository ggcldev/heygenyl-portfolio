---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../data/site";
import { getBlogPostSlug } from "../../utils/blog";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: `${siteConfig.name} Blog`,
    url: new URL("/blog/", siteConfig.url).toString(),
  },
];
---

<BaseLayout
  title="SEO Blog | Hey Genyl"
  description="SEO blog hub for technical SEO, local SEO, WordPress, and implementation-focused search insights."
  schema={schema}
>
  <div class="blog-page-view">
    <section class="content-shell py-12 md:py-16 lg:py-20">
      <div
        class="section-heading max-w-3xl mx-auto text-left border-b pb-8 gap-4 md:gap-5"
        style="border-color: var(--color-border);"
      >
        <p class="eyebrow">Blog</p>
        <h1>A blog for those who know Googling 'how to rank on Google' only gets you so far.</h1>
        <p class="post-meta">
          Weekly posts on Local SEO, Technical SEO, WordPress, and what I've picked up along the way.
        </p>
      </div>
    </section>

    <section class="content-shell pb-12">
      {posts.length > 0 && (
        <div class="blog-story-grid">
          {posts.map((post) => (
            <a class="blog-story-card" href={`/blog/${getBlogPostSlug(post)}/`}>
              <figure class="blog-story-card__media">
                {post.data.image ? (
                  <Picture
                    src={post.data.image}
                    alt={post.data.imageAlt ?? post.data.title}
                    formats={["avif", "webp"]}
                    fallbackFormat="webp"
                    widths={[480, 720, 960]}
                    sizes="(max-width: 767px) 100vw, (max-width: 1279px) 50vw, 480px"
                    quality={70}
                    loading="lazy"
                    decoding="async"
                    class="blog-story-card__image"
                  />
                ) : (
                  <div class="blog-story-card__placeholder" aria-hidden="true"></div>
                )}
              </figure>
              <div class="blog-story-card__content">
                <p class="eyebrow blog-story-card__date">
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </p>
                <h2 class="blog-story-card__title">{post.data.title}</h2>
                <p class="blog-story-card__excerpt">{post.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>
